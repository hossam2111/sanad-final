# =============================================================================
# SANAD AI Health Intelligence Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running the server.
# NEVER commit the .env file to version control.
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, RDS, or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/sanad?sslmode=require

# ─── Authentication ───────────────────────────────────────────────────────────
# JWT signing secret — use at least 64 random characters in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-before-deployment

# ─── AI Brain (Optional) ──────────────────────────────────────────────────────
# Used for AI narrative generation and clinical Q&A.
# If not set, AI endpoints return 503. System works without it.
OPENAI_API_KEY=sk-...

# Gemini API key for primary AI (optional — falls back to GPT-4o if missing)
GEMINI_API_KEY=...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Add your Vercel frontend URL here (e.g. https://sanad-xyz.vercel.app)
ALLOWED_ORIGINS=https://sanad.health.gov.sa,https://sanad-admin.health.gov.sa

# ─── Frontend → API (Vercel) ──────────────────────────────────────────────────
# Set this in your Vercel project's Environment Variables dashboard.
# Points the Next.js API rewrite to the deployed Express server.
# Example: https://sanad-api.railway.app
SANAD_API_URL=http://localhost:8080

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
