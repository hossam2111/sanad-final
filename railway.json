{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile && pnpm --filter @workspace/api-server build"
  },
  "deploy": {
    "startCommand": "node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "healthcheckPath": "/api/livez",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
